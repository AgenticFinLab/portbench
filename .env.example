# PortBench Environment Variables

# Kaggle API Token for accessing Kaggle datasets
KAGGLE_API_TOKEN=xxx
# Federal Reserve Economic Data API Key for accessing FRED datasets
FRED_API_KEY=xxx
# U.S. Securities and Exchange Commission API Key for accessing SEC datasets
SEC_API_KEY=xxx

# Qwen Model
DASHSCOPE_API_KEY=xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-plus

# Hunyuan Model
TENCENT_SECRET_ID=xxx
TENCENT_SECRET_KEY=xxx
TENCENT_API_KEY=xxx
TENCENT_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_MODEL=hy3-preview

# DeepSeek Model
DEEPSEEK_API_KEY=xxx
DEEPSEEK_BASE_URL=https://tokenhub.tencentmaas.com/v1
# DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-flash

# DouBao-Seed Model
ARK_API_KEY=xxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-2-0-pro-260215
ARK_MODEL=doubao-seed-2-0-lite-260215

# OpenAI Model
OPENAI_API_KEY=xxx
OPENAI_BASE_URL=xxx
OPENAI_MODEL=xxx

# Anthropic Model
ANTHROPIC_API_KEY=xxx
ANTHROPIC_BASE_URL=xxx
ANTHROPIC_MODEL=xxx

# Google Model
GOOGLE_API_KEY=xxx
GOOGLE_BASE_URL=xxx
GOOGLE_MODEL=xxx

